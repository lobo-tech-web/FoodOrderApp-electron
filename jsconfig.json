{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",

    "baseUrl": ".",

    "paths": {
      "@/*": ["vendor/client-src/*"]
    },

    "jsx": "react-jsx",
    "strict": false,
    "ignoreDeprecations": "6.0"
  },
  "include": [
    "src/**/*",
    "vendor/client-src/**/*",
    "main.js",
    "menu.js",
    "preload.js",
    "printer-manager.js",
    "updater.js",
    "scripts/**/*",
    "vite.config.mjs"
  ],
  "exclude": ["node_modules", "dist", "release"]
}
